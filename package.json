{
  "name": "pinyin-tool-extension",
  "version": "1.0.3",
  "description": "Chrome extension for Chinese text pinyin annotations and translations",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/download-cedict.mjs",
    "predev": "node scripts/download-cedict.mjs",
    "prebuild": "node scripts/download-cedict.mjs",
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "download:cedict": "node scripts/download-cedict.mjs",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "dompurify": "^3.4.0",
    "epubjs": "^0.3.93",
    "mammoth": "^1.12.0",
    "marked": "^18.0.1",
    "pdfjs-dist": "^5.6.205",
    "pinyin-pro": "^3",
    "tesseract.js": "^5"
  },
  "devDependencies": {
    "@types/chrome": "^0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-web-extension": "^4",
    "vitest": "^4",
    "vitest-chrome-mv3": "^1"
  }
}
